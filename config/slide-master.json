{
  "slide": {
    "aspectRatios": {
      "16:9": {
        "label": "16:9 宽屏",
        "width": { "px": 1280, "inches": 13.333 },
        "height": { "px": 720, "inches": 7.5 }
      },
      "4:3": {
        "label": "4:3 传统",
        "width": { "px": 960, "inches": 10.0 },
        "height": { "px": 720, "inches": 7.5 }
      },
      "21:9": {
        "label": "21:9 超宽",
        "width": { "px": 1680, "inches": 17.5 },
        "height": { "px": 720, "inches": 7.5 }
      },
      "22:5": {
        "label": "22:5 超宽带",
        "width": { "px": 3168, "inches": 33.0 },
        "height": { "px": 720, "inches": 7.5 }
      }
    },
    "defaultAspectRatio": "16:9",
    "baseMargin": {
      "top": { "px": 20 },
      "right": { "px": 40 },
      "bottom": { "px": 40 },
      "left": { "px": 40 }
    }
  },

  "contentAreas": {
    "header": {
      "heights": {
        "compact": { "px": 60, "label": "紧凑" },
        "normal": { "px": 75, "label": "标准" },
        "spacious": { "px": 90, "label": "宽松" }
      },
      "default": "compact"
    },
    "titleStyles": {
      "none": { "label": "无" },
      "simple": { "label": "简单" },
      "with-tag": { "label": "带标签" }
    },
    "titleStyleDefault": "with-tag",
    "footer": {
      "heights": {
        "compact": { "px": 15, "label": "紧凑" },
        "normal": { "px": 20, "label": "标准" },
        "spacious": { "px": 25, "label": "宽松" }
      },
      "default": "compact"
    },
    "sourceStyles": {
      "none": { "label": "无" },
      "citation": { "label": "显示" }
    },
    "sourceStyleDefault": "citation",
    "bodyGap": { "px": 8 }
  },

  "placeholders": {
    "logo": {
      "label": "Logo",
      "positions": {
        "tl": { "label": "左上", "position": { "top": 24, "left": 40 } },
        "tr": { "label": "右上", "position": { "top": 24, "right": 40 } },
        "bl": { "label": "左下", "position": { "bottom": 40, "left": 40 } },
        "br": { "label": "右下", "position": { "bottom": 40, "right": 40 } }
      },
      "defaultPosition": "tl",
      "sizes": {
        "small": { "width": 60, "height": 24, "label": "小" },
        "medium": { "width": 80, "height": 30, "label": "中" },
        "large": { "width": 120, "height": 45, "label": "大" }
      },
      "defaultSize": "medium",
      "allowUpload": true
    },
    "page-number": {
      "label": "页码",
      "positions": {
        "bl": { "label": "左下", "position": { "bottom": 20, "left": 60 } },
        "br": { "label": "右下", "position": { "bottom": 20, "right": 60 } },
        "bc": { "label": "底中", "position": { "bottom": 20 } }
      },
      "defaultPosition": "br"
    },
    "date": {
      "label": "日期",
      "positions": {
        "bl": { "label": "左下", "position": { "bottom": 20, "left": 60 } },
        "br": { "label": "右下", "position": { "bottom": 20, "right": 60 } }
      },
      "defaultPosition": "bl"
    }
  },

  "shapes": {
    "header-badge": {
      "label": "Header Badge",
      "occupiesSpace": false,
      "defaultContent": "SECTION",
      "comment": "Decorative badge at corner, does not affect content layout",
      "presets": {
        "pill-right": {
          "name": "Pill Right",
          "position": { "top": 20, "right": 0 },
          "size": { "width": 140, "height": 40 },
          "style": { "borderRadius": "20px 0 0 20px" }
        },
        "pill-left": {
          "name": "Pill Left",
          "position": { "top": 20, "left": 0 },
          "size": { "width": 140, "height": 40 },
          "style": { "borderRadius": "0 20px 20px 0" }
        },
        "tag-right": {
          "name": "Tag Right",
          "position": { "top": 20, "right": 0 },
          "size": { "width": 120, "height": 32 },
          "style": { "borderRadius": "4px 0 0 4px" }
        },
        "banner": {
          "name": "Banner",
          "position": { "top": 0, "right": 0 },
          "size": { "width": 200, "height": 36 },
          "style": { "borderRadius": "0" }
        }
      }
    },

    "header-line": {
      "label": "Header Line",
      "occupiesSpace": true,
      "comment": "Line below title area (header bottom ~80px)",
      "presets": {
        "full": {
          "name": "Full Width",
          "position": { "top": 82, "left": 0, "right": 0 },
          "bounds": { "top": 82 },
          "size": { "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "center": {
          "name": "Center",
          "position": { "top": 82, "left": 40, "right": 40 },
          "bounds": { "top": 82 },
          "size": { "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "left-half": {
          "name": "Left Half",
          "position": { "top": 82, "left": 0 },
          "bounds": { "top": 82 },
          "size": { "width": "50%", "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "right-half": {
          "name": "Right Half",
          "position": { "top": 82, "right": 0 },
          "bounds": { "top": 82 },
          "size": { "width": "50%", "height": 2 },
          "style": { "opacity": 0.3 }
        }
      }
    },

    "footer-line": {
      "label": "Footer Line",
      "occupiesSpace": true,
      "comment": "Line above source citation (footer top ~60px from bottom)",
      "presets": {
        "full": {
          "name": "Full Width",
          "position": { "bottom": 62, "left": 0, "right": 0 },
          "bounds": { "bottom": 62 },
          "size": { "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "center": {
          "name": "Center",
          "position": { "bottom": 62, "left": 40, "right": 40 },
          "bounds": { "bottom": 62 },
          "size": { "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "left-half": {
          "name": "Left Half",
          "position": { "bottom": 62, "left": 0 },
          "bounds": { "bottom": 62 },
          "size": { "width": "50%", "height": 2 },
          "style": { "opacity": 0.3 }
        },
        "right-half": {
          "name": "Right Half",
          "position": { "bottom": 62, "right": 0 },
          "bounds": { "bottom": 62 },
          "size": { "width": "50%", "height": 2 },
          "style": { "opacity": 0.3 }
        }
      }
    },

    "side-bar": {
      "label": "Side Bar",
      "occupiesSpace": true,
      "configType": "thickness-positions",
      "thickness": {
        "thin": { "size": 8, "boundsOffset": 20, "label": "细" },
        "thick": { "size": 20, "boundsOffset": 40, "label": "粗" }
      },
      "positions": {
        "left": { "label": "左" },
        "right": { "label": "右" },
        "top": { "label": "上" },
        "bottom": { "label": "下" }
      },
      "defaultThickness": "thin",
      "defaultPositions": ["left"]
    },

    "corner": {
      "label": "Corner Triangle",
      "occupiesSpace": false,
      "configType": "thickness-positions",
      "thickness": {
        "small": { "size": 60, "label": "小" },
        "large": { "size": 120, "label": "大" }
      },
      "positions": {
        "tl": { "label": "左上" },
        "tr": { "label": "右上" },
        "bl": { "label": "左下" },
        "br": { "label": "右下" }
      },
      "defaultThickness": "small",
      "defaultPositions": ["tl"],
      "style": { "opacity": 0.15 }
    },

    "corner-dots": {
      "label": "Corner Dots",
      "occupiesSpace": false,
      "configType": "thickness-positions",
      "thickness": {
        "small": { "size": 40, "dotSize": 2, "gap": 8, "label": "小" },
        "large": { "size": 80, "dotSize": 3, "gap": 12, "label": "大" }
      },
      "positions": {
        "tl": { "label": "左上" },
        "tr": { "label": "右上" },
        "bl": { "label": "左下" },
        "br": { "label": "右下" }
      },
      "defaultThickness": "small",
      "defaultPositions": ["br"],
      "style": { "opacity": 0.3 }
    },

    "corner-lines": {
      "label": "Corner Lines",
      "occupiesSpace": false,
      "configType": "thickness-positions",
      "thickness": {
        "small": { "size": 40, "lineWidth": 1, "gap": 8, "label": "小" },
        "large": { "size": 80, "lineWidth": 2, "gap": 12, "label": "大" }
      },
      "positions": {
        "tl": { "label": "左上" },
        "tr": { "label": "右上" },
        "bl": { "label": "左下" },
        "br": { "label": "右下" }
      },
      "defaultThickness": "small",
      "defaultPositions": ["tl"],
      "style": { "opacity": 0.2 }
    },

    "accent-circle": {
      "label": "Accent Circle",
      "occupiesSpace": false,
      "configType": "thickness-positions",
      "thickness": {
        "small": { "size": 100, "offset": -25, "label": "小" },
        "large": { "size": 180, "offset": -50, "label": "大" }
      },
      "positions": {
        "tl": { "label": "左上" },
        "tr": { "label": "右上" },
        "bl": { "label": "左下" },
        "br": { "label": "右下" }
      },
      "defaultThickness": "small",
      "defaultPositions": ["br"],
      "style": { "opacity": 0.08 }
    },

    "accent-ring": {
      "label": "Accent Ring",
      "occupiesSpace": false,
      "configType": "thickness-positions",
      "thickness": {
        "small": { "size": 80, "strokeWidth": 3, "offset": -20, "label": "小" },
        "large": { "size": 150, "strokeWidth": 5, "offset": -40, "label": "大" }
      },
      "positions": {
        "tl": { "label": "左上" },
        "tr": { "label": "右上" },
        "bl": { "label": "左下" },
        "br": { "label": "右下" }
      },
      "defaultThickness": "small",
      "defaultPositions": ["tl"],
      "style": { "opacity": 0.15 }
    }
  },

